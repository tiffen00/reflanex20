API_TOKEN=change-me-or-leave-blank-to-autogenerate
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ADMIN_IDS=123456789,987654321
DOMAINS=promo1.example.com,offer-x.example.net
DATABASE_URL=sqlite:///./storage/app.db
STORAGE_DIR=./storage/campaigns
MAX_ZIP_SIZE_MB=50
PUBLIC_BASE_URL=https://reflanex20.onrender.com

# Web auth (username/password login)
WEB_USERNAME=admin
WEB_PASSWORD=change-me                       # plain text OK for MVP; will be hashed in memory
SESSION_SECRET=                              # auto-generated at first start if empty (persisted to storage/.session_secret)
SESSION_TTL_HOURS=24
LOGIN_RATE_LIMIT_PER_15MIN=5

# Admin portal URL obfuscation (keep secret — this is the path to the login page)
ADMIN_PATH_PREFIX=/web/setlink/connect/service/ww/ww/wwww/www

# OTP fallback: set to true in dev to log OTP codes to stdout instead of Telegram
OTP_FALLBACK_LOG=false
