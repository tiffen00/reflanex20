# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=campaigns

# GeoIP
GEOIP_PROVIDER=ipapi

# Features
ENABLE_CLICK_ALERTS=true

# Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ADMIN_IDS=123456789,987654321
DOMAINS=promo1.example.com,offer-x.example.net
MAX_ZIP_SIZE_MB=50
PUBLIC_BASE_URL=https://reflanex20.onrender.com

# Web auth
WEB_USERNAME=admin
WEB_PASSWORD=change-me
SESSION_SECRET=
SESSION_TTL_HOURS=24
LOGIN_RATE_LIMIT_PER_15MIN=5
ADMIN_PATH_PREFIX=/web/setlink/connect/service/ww/ww/wwww/www
OTP_FALLBACK_LOG=false

# Anti-bot protection
ANTIBOT_ENABLED=true
ANTIBOT_SECRET=                            # generate with: openssl rand -hex 32
ANTIBOT_DEFAULT_LEVEL=standard             # off | light | standard | maximum
ANTIBOT_REDIRECT_URL=https://www.google.com/
ANTIBOT_RATE_LIMIT_WINDOW_SEC=10
ANTIBOT_RATE_LIMIT_MAX=5
